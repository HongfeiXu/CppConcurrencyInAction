{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"macos-debug"
			],
			"windows": {
				"args": [
					"--build",
					"--preset",
					"windows-debug"
				]
			},
			"linux": {
				"args": [
					"--build",
					"--preset",
					"linux-debug"
				]
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Configure (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"macos-debug"
			],
			"windows": {
				"args": [
					"--preset",
					"windows-debug"
				]
			},
			"linux": {
				"args": [
					"--preset",
					"linux-debug"
				]
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Clean (Debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"macos-debug",
				"--target",
				"clean"
			],
			"windows": {
				"args": [
					"--build",
					"--preset",
					"windows-debug",
					"--target",
					"clean"
				]
			},
			"linux": {
				"args": [
					"--build",
					"--preset",
					"linux-debug",
					"--target",
					"clean"
				]
			},
			"problemMatcher": []
		}
	]
}
